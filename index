<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RAPTOR GO Energy Gel</title>
  <style>
    :root{
      --orange:#ff5a00;
      --dark:#111111;
      --bg:#f9f9f9;
      --line:#e5e7eb;
    }
    *{box-sizing:border-box;margin:0;padding:0;font-family:"Noto Sans Thai",Arial,sans-serif}
    body{background:#fff;color:var(--dark);line-height:1.5}
    .container{max-width:1120px;margin:auto;padding:20px}
    .hero{display:grid;grid-template-columns:1.1fr .9fr;gap:24px;align-items:center;padding:28px 0}
    .headline{font-size:64px;font-weight:900;line-height:1.05}
    .headline .orange{color:var(--orange)}
    .sub{margin-top:10px;font-size:44px;font-weight:800}
    .sub .orange{color:var(--orange)}
    .benefits{margin-top:30px;display:grid;grid-template-columns:repeat(3,minmax(160px,1fr));gap:16px}
    .benefit{border:2px solid #111;border-radius:16px;padding:14px;text-align:center;background:#fff}
    .icon{font-size:34px}
    .benefit h3{font-size:34px;margin-top:8px}
    .product-card{background:linear-gradient(180deg,#fff 0%,#fff3e8 100%);border:1px solid var(--line);border-radius:26px;padding:20px;text-align:center;box-shadow:0 18px 40px rgba(0,0,0,.08)}
    .product-card img{max-width:100%;height:560px;object-fit:contain}
    .price-strip{margin-top:8px;background:var(--orange);color:white;border-radius:18px;padding:18px}
    .price-strip h4{font-size:26px}
    .price{font-size:52px;font-weight:900;line-height:1.1}
    .old{font-size:18px;text-decoration:line-through;opacity:.9}
    .cta{display:flex;gap:12px;margin-top:14px;flex-wrap:wrap}
    .btn{display:inline-block;text-decoration:none;padding:14px 24px;border-radius:999px;font-weight:800}
    .btn-buy{background:var(--orange);color:#fff}
    .btn-chat{border:2px solid #111;color:#111}
    .section{margin-top:34px;background:var(--bg);border:1px solid var(--line);border-radius:24px;padding:24px}
    .section h2{font-size:34px;margin-bottom:12px}
    .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px}
    .card{background:#fff;border:1px solid var(--line);border-radius:16px;padding:14px}
    .card h3{font-size:20px;margin-bottom:6px}
    footer{margin:26px 0 10px;text-align:center;color:#6b7280}

    @media (max-width:900px){
      .hero{grid-template-columns:1fr}
      .headline{font-size:44px}
      .sub{font-size:30px}
      .benefits{grid-template-columns:1fr}
      .product-card img{height:430px}
      .price{font-size:40px}
    }
  </style>
</head>
<body>
  <main class="container">
    <section class="hero">
      <div>
        <h1 class="headline"><span class="orange">แร็พเตอร์โก</span> เอ็นเนอร์จี้ เจล</h1>
        <p class="sub">พลังงานทันที <span class="orange">120kcal</span> พร้อมลุยทุกกิจกรรม</p>

        <div class="benefits">
          <article class="benefit">
            <div class="icon">🦴</div>
            <h3>บำรุงกระดูก</h3>
          </article>
          <article class="benefit">
            <div class="icon">🛡️</div>
            <h3>ปลอดภัย</h3>
          </article>
          <article class="benefit">
            <div class="icon">🔋</div>
            <h3>เพิ่มพลังงาน</h3>
          </article>
        </div>

        <div class="cta">
          <a class="btn btn-buy" href="https://lin.ee/X56gq67" target="_blank" rel="noopener noreferrer">สั่งซื้อทันที</a>
          <a class="btn btn-chat" href="#details">ดูรายละเอียดสินค้า</a>
        </div>
      </div>

      <div class="product-card">
        <img src="Gemini_Generated_Image_fxahpafxahpafxah.png" alt="RAPTOR GO Energy Gel" />
        <div class="price-strip">
          <h4>สินค้าพร้อมส่ง จัดส่งไวทุกออเดอร์</h4>
          <div class="price">39 บาท / ซอง</div>
          <div class="old">ราคาปกติ 59 บาท</div>
        </div>
      </div>
    </section>

    <section class="section" id="details">
      <h2>จุดเด่นสินค้า</h2>
      <div class="grid">
        <div class="card">
          <h3>ให้พลังงานเร็ว</h3>
          <p>พลังงาน 120 kcal ต่อซอง เหมาะสำหรับก่อนวิ่ง ปั่นจักรยาน หรือออกกำลังกายระยะยาว</p>
        </div>
        <div class="card">
          <h3>พกพาง่าย</h3>
          <p>ซองขนาดกะทัดรัด ฉีกง่าย รับประทานสะดวก ระหว่างกิจกรรมได้ทันที</p>
        </div>
        <div class="card">
          <h3>วิตามินเสริม</h3>
          <p>มีวิตามิน B1, B3, B12 ช่วยเสริมการเผาผลาญพลังงานให้พร้อมลุยได้ต่อเนื่อง</p>
        </div>
        <div class="card">
          <h3>เหมาะกับสายกิจกรรม</h3>
          <p>เหมาะสำหรับนักวิ่ง นักปั่น นักกีฬา หรือคนทำงานที่ต้องการเติมพลังอย่างรวดเร็ว</p>
        </div>
      </div>
    </section>

    <footer>© 2026 RAPTOR GO Energy Gel</footer>
  </main>
</body>
</html>
